# Copy to .env (or .env.local) for local dev. Vite auto-loads these at dev/build time
# and inlines any VITE_-prefixed var into the bundle. .env.local overrides .env.
#
# NOTE: production builds do NOT use this file — see .env.production (committed), which
# bakes the /examlense same-origin API base into the deployed bundle.

# Spring Boot backend base URL. Local default is the bootRun server on :8081.
VITE_API_BASE_URL=http://localhost:8081

# Static bearer token — must match the backend's API_AUTH_TOKEN (also "dev-local-token").
# Baked into the bundle, so it is not secret.
VITE_API_AUTH_TOKEN=dev-local-token
