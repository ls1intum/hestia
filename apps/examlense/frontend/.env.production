# Baked into the client bundle by `npm run build` (Vite auto-loads .env.production).
#
# Same-origin API: requests go to /examlense/api/... which Traefik strips to /api/... and
# the web (nginx) container proxies to the server. Keep this in sync with vite.config `base`.
VITE_API_BASE_URL=/examlense

# Single-user static bearer token. It is COMPILED INTO THE BROWSER BUNDLE, so it is not
# secret — it only needs to match the backend's API_AUTH_TOKEN (see compose.prod.yaml).
VITE_API_AUTH_TOKEN=dev-local-token
