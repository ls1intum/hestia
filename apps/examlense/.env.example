# Copy to .env and adjust for a manual/fallback deploy on the VM (.env is gitignored).
# In CI these values come from the GitHub environment secrets/variables; the reusable
# deploy workflow writes them into .env next to the injected IMAGE_TAG. Any name that
# compose.prod.yaml references must exist here (or as a GitHub secret/variable).

# Image tag to run (CI injects this; defaults to latest for a manual deploy).
IMAGE_TAG=latest

# Public host (must match the TLS cert SAN). This is a shared variable in the deploy
# environment (the VM FQDN, same for every app on the VM). The URL path prefix (/examlense)
# is NOT here — it is hardcoded in compose.prod.yaml so it can't collide with another app's
# shared APP_PATH_PREFIX.
APP_HOST=hestia-test.aet.cit.tum.de

# Postgres (private to this app).
POSTGRES_DB=examlense
POSTGRES_USER=examlense
POSTGRES_PASSWORD=change-me

# GWDG AI key (OpenAI-compatible). Named SAIA_API_KEY to match the shared deploy secret;
# compose maps it to the backend's AI_API_KEY. AI_BASE_URL defaults to the GWDG endpoint in
# compose.prod.yaml — only set it here to override.
SAIA_API_KEY=
# AI_BASE_URL=https://chat-ai.academiccloud.de/v1

# OpenAI native API — enables gpt-* parser/solver strategies.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic native API — enables claude-* parser/solver strategies.
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini API key (Google AI Studio) — enables the gemini-* PDF parser strategies.
# Optional: leave blank to disable them. NOTE: the free tier may use submitted content for
# training — do not use it for confidential exams.
GEMINI_API_KEY=

# LearningGoalHub base URL — derives learning goals per exam task at section confirm.
# Defaults to the deployed instance in compose.prod.yaml; only set here to override
# (e.g. http://localhost:8080 for a local LGH).
LGH_BASE_URL=https://hestia-test.aet.cit.tum.de/learninggoalhub

# Static bearer token. Baked into the frontend bundle too, so it is NOT secret — it only
# needs to match frontend/.env.production's VITE_API_AUTH_TOKEN.
API_AUTH_TOKEN=dev-local-token

# JVM options for the server container; heap is sized from the container mem_limit.
JAVA_OPTS=-XX:MaxRAMPercentage=70
