# Copy to .env and fill in. Load with: set -a; source .env; set +a
# (Spring Boot does not auto-read .env files.)

# --- Auth ---
# Single-user backend: a static bearer token gates the API (no real user auth yet).
# Must match the frontend's VITE_API_AUTH_TOKEN (also "dev-local-token" by default).
API_AUTH_TOKEN=dev-local-token

# Dedicated HMAC key for signed file URLs (/api/files/**). Recommended in
# deployments: keeps the URL-signing key separate from the bearer token, so
# rotating the token doesn't invalidate outstanding URLs. When unset, the
# backend falls back to API_AUTH_TOKEN and logs a warning at startup.
FILES_SIGNING_SECRET=

# Trust X-Forwarded-For for the per-IP rate limiter. Enable ONLY when the
# backend sits behind a reverse proxy; otherwise clients could spoof their IP.
API_RATELIMIT_BEHIND_PROXY=false

# --- AI providers ---
# GWDG (OpenAI-compatible) — the primary provider.
AI_API_KEY=
AI_BASE_URL=https://chat-ai.academiccloud.de/v1

# OpenAI (native Responses API) — optional; enables gpt-* parser/solver strategies.
# OPENAI_BASE_URL has a working default, so it's rarely needed.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (native Messages API) — optional; enables claude-* parser/solver strategies.
# ANTHROPIC_BASE_URL has a working default, so it's rarely needed.
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini (native API) — optional; enables the gemini-* PDF parser strategies.
# Leave blank to disable them. GEMINI_BASE_URL has a working default, so it's rarely needed.
GEMINI_API_KEY=

# --- HTTP server ---
PORT=8081
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
