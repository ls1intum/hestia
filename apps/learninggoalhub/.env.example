# Copy to .env and adjust as needed. .env is gitignored.

# Postgres (used by compose.yaml and compose.prod.yaml)
POSTGRES_DB=learninggoalhub
POSTGRES_USER=learninggoalhub
POSTGRES_PASSWORD=learninggoalhub
POSTGRES_PORT=5432

# GWDG SAIA (consumed by the server)
SAIA_API_KEY=

# Deployment only (compose.prod.yaml). In CI these come from GitHub environment
# secrets/variables; this file is for manual deploys on the VM. The shared Traefik proxy
# (infra/traefik) owns host ports 80/443 and terminates TLS, so this app publishes no host
# port — it is routed by host + path prefix instead.
# Image tag to run (CI injects this; defaults to latest for a manual deploy).
IMAGE_TAG=latest
# Public hostname this app answers on (must match the TLS cert SAN). e.g. your VM's FQDN.
APP_HOST=your-vm.example.tum.de
# URL path prefix this app is served under: https://<APP_HOST><APP_PATH_PREFIX>/...
APP_PATH_PREFIX=/learninggoalhub
# JVM options for the server container; heap is sized from the container mem_limit.
JAVA_OPTS=-XX:MaxRAMPercentage=70
